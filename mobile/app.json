{
  "expo": {
    "name": "CertChain",
    "slug": "certchain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0a0f",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.certchain.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CertChain uses the camera to scan certificate QR codes for instant verification.",
        "NSFaceIDUsageDescription": "CertChain uses Face ID for secure wallet authentication."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.certchain.app",
      "permissions": ["CAMERA", "USE_FINGERPRINT", "USE_BIOMETRIC"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow CertChain to access the camera for QR scanning." }],
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
