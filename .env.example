# ─── BLOCKCHAIN ──────────────────────────────────────────────────
# Local Hardhat node
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Mumbai testnet
# RPC_URL=https://rpc-mumbai.maticvigil.com
# CHAIN_ID=80001

# Polygon mainnet
# RPC_URL=https://polygon-rpc.com
# CHAIN_ID=137

# Filled in automatically after: npm run deploy:local
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Your deployer wallet private key — NEVER commit this
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── GOOGLE AUTH ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── SECURITY ────────────────────────────────────────────────────
# Change this in production — use a 64-char random hex string
JWT_SECRET=certchain-dev-secret-change-this-in-production-to-random-64-char-hex

# ─── IPFS ────────────────────────────────────────────────────────
# Local IPFS daemon (run: ipfs daemon)
IPFS_API=/dns/localhost/tcp/5001/http

# Or use Pinata cloud (no local daemon needed)
# PINATA_API_KEY=your-pinata-key
# PINATA_SECRET=your-pinata-secret

# ─── OPTIONAL: BLOCK EXPLORER VERIFICATION ───────────────────────
POLYGONSCAN_API_KEY=your-polygonscan-api-key
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_RPC_URL=https://polygon-rpc.com
